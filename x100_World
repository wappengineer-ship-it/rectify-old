x053.ImproveWeapon = function () {
    if (x.Nuggets >= x100.WeaponLevel*500){
        x.Nuggets -= x100.WeaponLevel*500;
        localStorage.Nuggets = x.Nuggets;
        x100.WeaponLevel++
        localStorage.WeaponLevel = x100.WeaponLevel;
        x053.UpdateBarracks()
        x.UpdateBar()
    }
};


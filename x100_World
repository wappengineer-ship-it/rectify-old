    ctx.beginPath()
    ctx.rect(canvas.width/2 -5, y, 10, 10);
    ctx.fillStyle = x100.BodyColor;
    ctx.fill();
    ctx.stroke();
    ctx.closePath();    

    for (var i = 1; i <= x100.Followers; i++){

        if (x100.Displacement > -10000){
            y = canvas.height*0.7;
        } else {
            y = x100.Terrain[canvas.width/2 -5 - pDirection*i*20 + x100.Terrain_i] - 10;
        }
        if (i < x100.Camels) {
            ctx.beginPath()
            ctx.rect(canvas.width/2 - pDirection*i*20 -20, y, 40, 10);
            ctx.fillStyle = '#ffdd80';
            ctx.fill();
            ctx.stroke();
            ctx.closePath();    

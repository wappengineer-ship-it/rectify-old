
var x100 = {}; //First Scene

x100.Displacement = parseInt(localStorage.Displacement) || 0;

x100.Terrain_i = parseInt(localStorage.Terrain_i) || 0;
if(localStorage.Terrain){
    x100.Terrain = JSON.parse(localStorage.Terrain);
} else {
    x100.Terrain = [];
}


x100.MaxDisplacement = parseInt(localStorage.MaxDisplacement) || 0;


x100.Begin = function () {
    var h = '<div>'
    h += '<canvas id = "x100_Canvas"></canvas>';
    h += '</div>';
    
    h += '<div class="CenterDiv">';
    h += x.GetButton('<', 'x100.Move(-1)', 'LeftButton');
    h += x.GetButton('<>', 'x100.Stop()', 'StopButton');
    h += x.GetButton('>', 'x100.Move(1)', 'RightButton');
    h += '</div>';

    x100.div = x.e('x100');
    x100.div.innerHTML = h;
    x.e('x100').style.display = 'grid';
    
    x.Hide('StopButton')

    const canvas = document.getElementById("x100_Canvas");
    x100.Canvas = canvas;

    x100.TerrainColor = 'Yellow';
    x100.SkyColor = 'Blue';
    x100.BodyColor = 'purple';

    if (x000.NewGame == true){
        localStorage.NewGame = false;
        x000.NewGame = false;
        const ctx = canvas.getContext("2d");

        var y = canvas.height*0.6;
        var sign;   
        var CharHeight;   

        x100.Slope = 0.3;
        for (var i = 0; i < canvas.width; i ++){
            sign = 2*Math.random();
            if (sign > 1) {
                sign = 1;
            } else {
                sign = -1;
            }
            y = y + sign*x100.Slope*Math.random()
            x100.Terrain.push(y);
            if (i == Math.floor(canvas.width)/2){
                //Height of character
                CharHeight = y;       
            }
            }
               
        //Land
        ctx.beginPath();
        ctx.moveTo(0, 100);
        for (var i = 0; i < x100.Terrain.length; i++){
        ctx.lineTo(i, x100.Terrain[i]);
        };
            
        ctx.fillStyle = x100.TerrainColor;
        ctx.lineTo(canvas.width, canvas.width);
        ctx.lineTo(0, canvas.width);
        ctx.stroke();
        ctx.fill();

        //Sky
        ctx.beginPath();
        ctx.moveTo(0, 100);
        for (var i = 0; i < x100.Terrain.length; i++){
        ctx.lineTo(i, x100.Terrain[i]);
        };
            
        ctx.fillStyle = x100.SkyColor;
        ctx.lineTo(canvas.width, 0);
        ctx.lineTo(0, 0);
        ctx.stroke();
        ctx.fill();

        ctx.closePath();
        ctx.beginPath();
        ctx.rect(canvas.width/2 -5, canvas.height*0.7, 10, 10);
            
        ctx.fillStyle = x100.BodyColor;
        ctx.fill();
        ctx.stroke();
        ctx.closePath();
        } else {

    }

    x100.Move(-1)
    setTimeout(x100.Stop, 10)
};

x100.Paint = function (pDirection){

                    ctx.rect(1200 - x100.Displacement + ct%5*15, y + ct, size, size);
                    ctx.fillStyle = 'orange';
                    ctx.fill();
                    ctx.stroke();
                    ctx.closePath();
                    ct++
                }
            } else {
                ctx.beginPath();
                ctx.rect(1200 - x100.Displacement, y, size, size);
                ctx.fillStyle = 'orange';
                ctx.fill();
                ctx.stroke();
                ctx.closePath();
            }
        }
    }

    if (x100.Displacement > - 6000 - canvas.width
    && x100.Displacement < -5000 + canvas.width){
    height += 10; //For builings
    ctx.beginPath();
    ctx.rect(-5100 - x100.Displacement, 
    height - 30, 60, 40);
    ctx.fillStyle = 'white';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5900 - x100.Displacement, 
    height - 30, 50, 50);
    ctx.fillStyle = 'white';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5300 - x100.Displacement, 
    height , 80, 30);
    ctx.fillStyle = 'white';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5500 - x100.Displacement, 
    height - 60, 140, 70);
    ctx.fillStyle = 'white';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5700 - x100.Displacement, 
    height - 30, 80, 40);
    ctx.fillStyle = 'white';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();



    //Peeps
    y = 0.7*canvas.height;
    ctx.beginPath();
    ctx.rect(-5000 - x100.Displacement, 
    y, 10, 10);
    ctx.fillStyle = 'lightblue';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5200 - x100.Displacement, 
    y, 10, 10);
    ctx.fillStyle = 'lightblue';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5550 - x100.Displacement, 
    y, 10, 10);
    ctx.fillStyle = 'lightblue';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();
        
    ctx.beginPath();
    ctx.rect(-5600 - x100.Displacement, 
    y, 10, 10);
    ctx.fillStyle = 'lightblue';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-5800 - x100.Displacement, 
    y, 10, 10);
    ctx.fillStyle = 'lightblue';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();

    ctx.beginPath();
    ctx.rect(-6000 - x100.Displacement, 
    y, 10, 10);
    ctx.fillStyle = 'lightblue';
    ctx.fill();
    ctx.stroke();
    ctx.closePath();
    }
};


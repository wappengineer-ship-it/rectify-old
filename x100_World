    }

    if (x100.Displacement == -5800 && !localStorage.Mission1){
        localStorage.Mission1 = 'true';
        x100.Stop()
        x052.Begin('x100', 'Please help me!', 
        //'Please deliver this letter to the my son in the next village East.', 
        'A warrior! Please help us with the bandits, I beg of you.', 

            function () {
                x.Hide('x050')
                x100.Begin()
            }
        );   
    }


    const canvas = x100.Canvas;
    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (pDirection == -1){
        var y = x100.Terrain[x100.Terrain_i];
        x100.Terrain_i--
        if (x100.Terrain_i < 0){
            x100.Terrain_i = 0;
        }

    } else if (pDirection == 1){
        x100.Terrain_i++
        var y = x100.Terrain[x100.Terrain_i  + canvas.width - 1];
        if (!y){y = canvas.height*0.6;}

    }

    var sign;
            
    sign = 2*Math.random();
    if (sign > 1) {
        sign = 1;
    } else {
        sign = -1;
    }
                
    if (x100.Displacement < -10000){
        x100.Slope = 2;
        x100.TerrainColor = 'gray';

        var Roll = Math.ceil(Math.random()*250)
        if (Roll <= 1*(x100.Followers + 1)){
            x.Nuggets ++;
            //localStorage.Nuggets = x.Nuggets;
            x.e('xBottomBar').innerHTML = 'Level ' + x.Level + ' | Nuggets: ' + x.Nuggets;
        }
    } else {
        x100.Slope = 0.3;
        x100.TerrainColor = 'yellow';
    }

    if (x100.Displacement > 300){  
        x100.Slope = 5;
    }

    y = y + sign*x100.Slope*Math.random()

    if(x100.TerrainColor == 'yellow'){
        if (y < canvas.height*0.5){
            y = canvas.height*0.5;
        }
        if (y > canvas.height*0.7){
            y = canvas.height*0.7;
        }
    }

    if(x100.TerrainColor == 'gray'){
        if (y < canvas.height*0.1){
            y = canvas.height*0.1;
        }
        if (y > canvas.height*0.7){
            y = canvas.height*0.7;
        }
    }

    var CharHeight;
    CharHeight =x100.Terrain[x100.Terrain_i + Math.floor(canvas.width/2)];  


        ctx.lineTo(i, x100.Terrain[i + x100.Terrain_i]);
    };
    ctx.lineTo(canvas.width, canvas.width);
    ctx.lineTo(0, canvas.width);
    ctx.stroke();
    ctx.fill();
    ctx.closePath();

    //Sky
    ctx.beginPath();
    ctx.moveTo(0, 100);
    for (var i = 0; i < canvas.width; i++){
        ctx.lineTo(i, x100.Terrain[i + x100.Terrain_i]);
    };

    //x100.SkyColor = 'Blue';
    ctx.fillStyle = x100.SkyColor;
    ctx.lineTo(canvas.width, 0);
    ctx.lineTo(0, 0);
    ctx.stroke();
    ctx.fill();

    //Town Wall
    if (x100.Displacement > - 6000 - canvas.width && x100.Displacement < -5000 + canvas.width){

        var height = canvas.height*0.7;
        CharHeight = height;

        ctx.fillStyle = 'brown';
        for (var i = -5000 - x100.Displacement; i> -6000 - x100.Displacement; i--){
            ctx.beginPath();
            ctx.rect(i, height - 15, 1, 15);
            ctx.fill();
            ctx.stroke();
            ctx.closePath();
